<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Concordia Campus Safety</title>
  <link rel="icon" href="images/concordia-logo.png">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link rel="stylesheet" href="styles/global.css">
  <link rel="stylesheet" href="styles/map.css">
  <link rel="stylesheet" href="styles/cards.css">
  <link rel="stylesheet" href="styles/pages.css">
</head>
<body class="page-body">

  <!-- Header -->
  <header class="app-header">
    <div class="logo" onclick="window.location.href='index.html'">
      <div class="logo-circle">C</div>
      <span class="logo-text">Concordia Safety</span>
    </div>
    <nav class="desktop-nav">
      <a href="index.html" class="active">Map</a>
      <a href="pages/report.html">Report</a>
      <a href="pages/alert-history.html">Alerts</a>
      <a href="pages/profile.html">Profile</a>
    </nav>
    <div class="header-actions">
      <button type="button" class="header-btn crisis-btn-js" title="Crisis Mode">!</button>
      <button type="button" class="header-btn avatar-btn-js" title="Profile" onclick="window.location.href='pages/profile.html'">U</button>
    </div>
  </header>

  <!-- Offline Banner -->
  <div id="offline-banner">📡 Offline Mode — Using cached data. Data may be delayed.</div>

  <!-- Crisis Banner -->
  <div class="crisis-banner">⚠️ CRISIS MODE ACTIVE — Map only, stay safe</div>

  <!-- Main Content -->
  <main class="homepage-layout">
    <!-- Map Column -->
    <div class="map-column">
      <div class="map-section">
        <div class="map-container">
          <div id="map-js"></div>
          <!-- Legend toggle (mobile) -->
          <button type="button" class="map-legend-toggle" id="legend-toggle-js">🗺</button>
          <!-- Legend -->
          <div class="map-legend collapsed" id="map-legend-js">
            <div class="map-legend-title">Legend</div>
            <div class="map-legend-item"><img src="images/concordia-logo.png" alt=""> Building</div>
            <div class="map-legend-item">📢 Protest</div>
            <div class="map-legend-item">🚧 Construction</div>
            <div class="map-legend-item">🛗 Elevator</div>
            <div class="map-legend-item">🌨️ Weather</div>
            <div class="map-legend-item">⚠️ Others</div>
          </div>
        </div>
      </div>
    </div>

    <!-- List Column (alert cards) -->
    <div class="list-column">
      <!-- Filter pills -->
      <div class="filter-bar" id="filter-bar-js">
        <button type="button" class="filter-pill active" data-filter="all">All</button>
        <button type="button" class="filter-pill" data-filter="ACTIVE">Active <span class="pill-badge" id="active-count-js">0</span></button>
        <button type="button" class="filter-pill" data-filter="UNDER REVIEW">Review</button>
        <button type="button" class="filter-pill" data-filter="RESOLVED">Resolved</button>
      </div>

      <!-- Alert card list -->
      <div class="alert-section" id="alert-list-js">
        <div class="alert-empty">Loading alerts...</div>
      </div>
    </div>
  </main>

  <!-- Crisis Call button (visible in crisis mode) -->
  <a href="tel:5148483717" class="crisis-call">📞 Call Campus Security: 514-848-3717</a>

  <!-- Bottom Tab Bar (mobile only) -->
  <nav class="tab-bar">
    <a class="tab-item active" href="index.html">
      <span class="tab-icon">🗺</span>
      <span>Map</span>
    </a>
    <a class="tab-fab" href="pages/report.html" title="Report Hazard">+</a>
    <a class="tab-item" href="pages/profile.html">
      <span class="tab-icon">👤</span>
      <span>Profile</span>
    </a>
  </nav>

  <!-- Scripts -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="scripts/api.js"></script>
  <script src="scripts/auth.js"></script>
  <script src="data/building.js"></script>
  <script src="scripts/map.js"></script>
  <script src="scripts/app.js"></script>
</body>
</html>
